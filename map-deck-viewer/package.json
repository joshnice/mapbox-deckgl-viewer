{
	"name": "@joshnice/map-deck-viewer",
	"description": "A mapbox class to add models easily",
	"version": "0.0.5",
	"private": false,
	"author": "joshnice",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
